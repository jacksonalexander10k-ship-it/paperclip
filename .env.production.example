# Aygency World — Production Environment Variables
# Copy to .env.production and fill in real values

# ── Public URL ────────────────────────────────────────────────────────────────
PUBLIC_URL=https://aygencyworld.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
PAPERCLIP_AGENT_JWT_SECRET=generate_with_openssl_rand_base64_32

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── WhatsApp / 360dialog ─────────────────────────────────────────────────────
DIALOG360_SANDBOX_API_KEY=your_360dialog_api_key
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── Google OAuth (Gmail + Calendar) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Meta (WhatsApp Business + Instagram) ─────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
