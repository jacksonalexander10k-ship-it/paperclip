# ============================================================
# Aygency World — Environment Variables
# Copy this file to .env and fill in the values marked REQUIRED
# ============================================================

# ── Core ────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ── Database ────────────────────────────────────────────────

# REQUIRED
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aygencyworld

# ── Auth (better-auth) ───────────────────────────────────────

# REQUIRED — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# REQUIRED — the URL of this app (used for auth redirects)
BETTER_AUTH_URL=http://localhost:3001

# ── AI ──────────────────────────────────────────────────────

# REQUIRED — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — for future Gemini Embedding 2 semantic matching (Phase 4)
GEMINI_API_KEY=

# ── AygentDesk Integration ───────────────────────────────────

# REQUIRED — URL of your AygentDesk instance
# Dev: http://localhost:3000 | Prod: https://aygentdesk.com
AYGENTDESK_URL=

# REQUIRED — shared secret for authenticating tool calls from Aygency World → AygentDesk
# Must match AYGENCY_WORLD_SECRET in AygentDesk's .env
# Generate with: openssl rand -base64 32
AYGENTDESK_INTERNAL_SECRET=

# ── Webhooks ────────────────────────────────────────────────

# Secret for verifying inbound webhook signatures
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ── WhatsApp / Meta ──────────────────────────────────────────
# Set these in Phase 2 when you connect your first real agency
# Get from: Meta Developer Console → your App

# Meta App credentials
META_APP_ID=
META_APP_SECRET=

# WhatsApp Cloud API — platform number (used before per-agent numbers are connected)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# 360dialog ISV credentials (Phase 2 — for Embedded Signup)
# Get after signing up at https://360dialog.com/partners
DIALOG360_ISV_CLIENT_ID=
DIALOG360_ISV_CLIENT_SECRET=
DIALOG360_PARTNER_ID=

# ── Gmail / Google ───────────────────────────────────────────
# Set these in Phase 2 when Gmail integration goes live

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pub/Sub push notification token (for Gmail real-time notifications)
GMAIL_PUBSUB_TOKEN=

# ── Push Notifications (VAPID) ───────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@aygencyworld.com

# ── Stripe (Phase 3) ─────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Tool Bridge (Phase 3) ────────────────────────────────────
# These are set automatically if Tool Bridge runs as a sibling service
TOOL_BRIDGE_URL=http://localhost:3002
TOOL_BRIDGE_SECRET=

# ── Webhook Receiver (Phase 2) ───────────────────────────────
WEBHOOK_RECEIVER_URL=http://localhost:3003
